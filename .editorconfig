# Editor configuration
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# YAML files (GitHub Actions safe)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files (keep trailing spaces for line breaks)
[*.md]
trim_trailing_whitespace = false
